# Vercel Postgres auto-injects both of these when you add a Postgres database in the Vercel dashboard.
# For local dev, copy them from Vercel project > Storage > your DB > .env.local tab.
# POSTGRES_URL        — pooled connection (PgBouncer), used at runtime
# POSTGRES_URL_NON_POOLING — direct connection, used only by prisma migrate deploy
POSTGRES_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Generate a strong random string: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# Anything you want — used to protect the /api/admin/seed endpoint
ADMIN_SECRET="change-me-too"
