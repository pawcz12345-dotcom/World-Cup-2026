# Vercel Postgres — copy these from your Vercel project > Storage > your DB > .env.local
DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgres://user:password@host.neon.tech/dbname?sslmode=require"

# Generate a strong random string: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# Anything you want — used to protect the /api/admin/seed endpoint
ADMIN_SECRET="change-me-too"
