// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  password            String
  createdAt           DateTime             @default(now())
  groupStandingPicks  GroupStandingPick[]
  bracketPicks        BracketPick[]
}

model GroupStandingPick {
  id     Int    @id @default(autoincrement())
  userId Int
  group  String // "A" through "L"
  rank1  String // team predicted to finish 1st
  rank2  String // team predicted to finish 2nd
  rank3  String // team predicted to finish 3rd
  rank4  String // team predicted to finish 4th
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, group])
}

model BracketPick {
  id     Int    @id @default(autoincrement())
  userId Int
  round  String // "R32" | "R16" | "QF" | "SF" | "Final"
  slot   Int    // slot number within that round
  team   String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, round, slot])
}

model MatchResult {
  id        Int     @id @default(autoincrement())
  matchId   String  @unique // "A1", "A2", etc.
  homeGoals Int?
  awayGoals Int?
  result    String? // "home" | "draw" | "away" (null = not played)
  status    String  @default("scheduled") // "scheduled" | "live" | "finished"
}
