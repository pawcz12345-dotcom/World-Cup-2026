// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                   Int               @id @default(autoincrement())
  username             String            @unique
  password             String
  displayName          String?
  avatarUrl            String?           @db.Text
  favoriteTeam         String?
  isAdmin              Boolean           @default(false)
  createdAt            DateTime          @default(now())
  entriesCount         Int               @default(1)
  announcementAckedAt  DateTime?
  chatLastReadId       Int               @default(0)
  bracketUnlocked      Boolean           @default(false)
  bracketInvalid       Boolean           @default(false)
  lastSeenAt           DateTime?
  matchPicks           MatchPick[]
  bracketPicks         BracketPick[]
  tiebreakerPicks      TiebreakerPick[]
  poolWins             PoolWin[]
  rankSnapshots        RankSnapshot[]
  chatMessages         ChatMessage[]
  chatReactions        ChatReaction[]
}

model MatchPick {
  id      Int    @id @default(autoincrement())
  userId  Int
  entry   Int    @default(1)
  matchId String // "A1" … "L6"
  pick    String // "home" | "draw" | "away"
  user    User   @relation(fields: [userId], references: [id])

  @@unique([userId, entry, matchId])
}

model BracketPick {
  id     Int    @id @default(autoincrement())
  userId Int
  entry  Int    @default(1)
  round  String // "R32" | "R16" | "QF" | "SF" | "Final"
  slot   Int    // slot number within that round
  team   String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, entry, round, slot])
}

model TiebreakerPick {
  id        Int    @id @default(autoincrement())
  userId    Int
  groupId   String // group letter e.g. "A", or "thirds" for cross-group 3rd-place ranking
  teamOrder String // JSON array of team names in user's preferred order
  user      User   @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
}

model MatchResult {
  id        Int     @id @default(autoincrement())
  matchId   String  @unique // "A1", "A2", etc.
  homeGoals Int?
  awayGoals Int?
  result    String? // "home" | "draw" | "away" (null = not played)
  status    String  @default("scheduled") // "scheduled" | "live" | "finished"
}

model BracketResult {
  id    Int    @id @default(autoincrement())
  round String // "R32" | "R16" | "QF" | "SF" | "Final"
  slot  Int    // slot number within that round
  team  String // winning team name

  @@unique([round, slot])
}

model PoolConfig {
  id                Int   @id @default(1)
  entryFeePerPlayer Float @default(0)
}

model RankSnapshot {
  id     Int    @id @default(autoincrement())
  userId Int
  user   User   @relation(fields: [userId], references: [id])
  entry  Int    @default(1)
  date   String // "YYYY-MM-DD" — kept current through the day, so a prior date holds end-of-day state
  rank   Int
  score  Int

  @@unique([userId, entry, date])
}

model PoolWin {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  poolName    String
  year        Int
  position    Int      @default(1)
  trophyImage String?  // path like "/images/world-cup-trophy.png"
  awardedAt   DateTime @default(now())
}

model OddsSnapshot {
  id        Int      @id @default(autoincrement())
  matchId   String   @unique
  home      Float
  draw      Float
  away      Float
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id])
  body      String         @db.Text
  imageUrl  String?        @db.Text
  createdAt DateTime       @default(now())
  reactions ChatReaction[]

  @@index([createdAt])
}

model ChatReaction {
  id        Int         @id @default(autoincrement())
  messageId Int
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  emoji     String

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model KnockoutMatch {
  id      Int       @id @default(autoincrement())
  round   String    // "R32" | "R16" | "QF" | "SF" | "Final"
  slot    Int       // slot index within the round
  home      String?   // team name (null until set by admin)
  away      String?
  kickoff   DateTime? // used for per-game locking and the scores display
  homeScore Int?      // persisted live/final score for the scores display
  awayScore Int?
  status    String    @default("scheduled") // "scheduled" | "live" | "finished"

  @@unique([round, slot])
}

// Frozen win-scenario percentages captured each time a knockout game resolves,
// so the scenarios page can show how each entry's odds moved since the last
// result. Keyed by the number of decided knockout slots at capture time.
model ScenarioSnapshot {
  id        Int      @id @default(autoincrement())
  signature Int      @unique // count of decided knockout slots when captured
  payload   String   @db.Text // JSON: { [entryKey]: { win: number, ev: number } }
  createdAt DateTime @default(now())
}
